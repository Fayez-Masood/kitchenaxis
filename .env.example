# ============================================================
# KitchenAxis — environment variables
# Copy this file to `.env.local` and fill in real values.
# The site works WITHOUT these set (leads are logged to the server
# console), but nothing is emailed or saved until you configure them.
# ============================================================

# ---------- Email delivery (SMTP) ----------
# Any SMTP provider works: Gmail App Password, Zoho, Microsoft 365,
# Amazon SES, Resend SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where new leads are emailed (defaults to SMTP_USER if empty):
LEAD_TO_EMAIL=
# The "From" address shown on lead emails:
LEAD_FROM_EMAIL=KitchenAxis <info@kitchenaxis.co>

# ---------- Google Sheet (via Apps Script Web App) ----------
# Deploy the script in docs/google-apps-script.gs as a Web App and paste
# its /exec URL here. See README for step-by-step.
GOOGLE_SHEET_WEBHOOK_URL=
# Optional shared secret checked by the Apps Script (recommended):
GOOGLE_SHEET_TOKEN=

# ---------- Google Analytics 4 + Google Ads (client-side gtag) ----------
# GA4 Measurement ID: Analytics > Admin > Data streams > (your stream).
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Google Ads ID for conversion tracking: Google Ads > Tools > Conversions.
# Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=
# The lead conversion action's label (the part after the slash in send_to).
# Format: xxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADS_LEAD_LABEL=

# ---------- Google Search Console ----------
# HTML-tag verification: the content value of the meta tag Google gives you
# (just the token, not the whole tag).
NEXT_PUBLIC_GSC_VERIFICATION=
